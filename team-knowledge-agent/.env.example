# Runtime
NODE_ENV=development
LOG_LEVEL=info

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.2
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Civic (MCP)
CIVIC_TOKEN=your_civic_token
CIVIC_PROFILE_ID=your_civic_profile_id
CIVIC_BASE_URL=https://app.civic.com/hub/mcp
CIVIC_LOCK_PROFILE=true

# Optional write destinations / policy filters (comma-separated where noted)
CIVIC_SLACK_WRITE_CHANNEL=
CIVIC_NOTION_WRITE_PAGE_IDS=
CIVIC_JIRA_PROJECT_KEYS=
CIVIC_GMAIL_LABEL_IDS=

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_pinecone_index
PINECONE_NAMESPACE=prod

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_knowledge_agent

# API
PORT=3000
API_AUTH_TOKEN=your_api_auth_token
